import os
import numpy as np
import cv2
import gymnasium as gym
from gymnasium import spaces
import vizdoom as vzd

FRAME_WIDTH = 84
FRAME_HEIGHT = 84
FRAME_STACK = 4


class DoomEnv(gym.Env):

    metadata = {"render_modes": ["human", "rgb_array"]}

    def __init__(self, scenario_path=None, render_mode=None):
        super().__init__()

        self.render_mode = render_mode
        self.game = vzd.DoomGame()

        if scenario_path is None:
            scenario_path = os.path.abspath(
                os.path.join(
                    os.path.dirname(__file__),
                    "..",
                    "config",
                    "basic.cfg"
                )
            )

        self.game.load_config(scenario_path)

        wad_path = os.path.join(vzd.scenarios_path, "basic.wad")
        self.game.set_doom_scenario_path(wad_path)

        if render_mode == "human":
            self.game.set_window_visible(True)
        else:
            self.game.set_window_visible(False)

        self.game.init()

        self.actions = [
            [True, False, False],
            [False, True, False],
            [False, False, True],
            [False, False, False],
        ]

        self.action_space = spaces.Discrete(len(self.actions))

        self.observation_space = spaces.Box(
            low=0,
            high=255,
            shape=(FRAME_STACK, FRAME_HEIGHT, FRAME_WIDTH),
            dtype=np.uint8
        )

        self.frame_stack = np.zeros(
            (FRAME_STACK, FRAME_HEIGHT, FRAME_WIDTH),
            dtype=np.uint8
        )

        self.prev_health = 100
        self.prev_ammo = 50
        self.prev_kills = 0
        self.steps_since_last_kill = 0

    def reset(self, seed=None, options=None):
        super().reset(seed=seed)

        self.game.new_episode()

        self.steps_since_last_kill = 0

        state = self.game.get_state()

        if state is not None and state.game_variables is not None:
            vars = state.game_variables

            if len(vars) >= 3:
                self.prev_health = vars[0]
                self.prev_ammo = vars[1]
                self.prev_kills = vars[2]

        frame = self._get_frame()

        for i in range(FRAME_STACK):
            self.frame_stack[i] = frame

        return self.frame_stack.copy(), {}

    def step(self, action):

        self.game.make_action(self.actions[action], 4)

        terminated = self.game.is_episode_finished()
        truncated = False

        if terminated:
            reward = self._compute_reward(True)
            return self.frame_stack.copy(), reward, terminated, truncated, {}

        frame = self._get_frame()

        self.frame_stack = np.roll(self.frame_stack, -1, axis=0)
        self.frame_stack[-1] = frame

        reward = self._compute_reward(False)

        self.steps_since_last_kill += 1

        return self.frame_stack.copy(), reward, terminated, truncated, {}

    def _compute_reward(self, terminal=False):

        reward = 0.0

        if terminal:
            return -25.0

        state = self.game.get_state()

        if state is None:
            return reward

        vars = state.game_variables

        if vars is None or len(vars) < 3:
            return reward

        current_health = vars[0]
        current_ammo = vars[1]
        current_kills = vars[2]

        kill_delta = current_kills - self.prev_kills
        health_delta = current_health - self.prev_health
        ammo_delta = current_ammo - self.prev_ammo

        if kill_delta > 0:
            reward += 50 * kill_delta
            self.steps_since_last_kill = 0

        reward += 0.05

        if health_delta < 0:
            reward += health_delta * 0.25

        if ammo_delta < 0 and kill_delta == 0:
            reward -= 0.1

        if self.steps_since_last_kill > 200:
            reward -= 0.05

        self.prev_health = current_health
        self.prev_ammo = current_ammo
        self.prev_kills = current_kills

        return reward

    def _get_frame(self):

        state = self.game.get_state()

        if state is None or state.screen_buffer is None:
            return np.zeros((FRAME_HEIGHT, FRAME_WIDTH), dtype=np.uint8)

        frame = state.screen_buffer

        if frame.ndim == 3 and frame.shape[0] in (1, 3, 4):
            frame = np.transpose(frame, (1, 2, 0))

        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

        resized = cv2.resize(
            gray,
            (FRAME_WIDTH, FRAME_HEIGHT),
            interpolation=cv2.INTER_AREA
        )

        return resized.astype(np.uint8)

    def render(self):

        if self.render_mode == "rgb_array":

            state = self.game.get_state()

            if state and state.screen_buffer is not None:

                frame = state.screen_buffer

                if frame.ndim == 3 and frame.shape[0] in (1, 3, 4):
                    frame = np.transpose(frame, (1, 2, 0))

                return cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)

        return None

    def close(self):

        if self.game is not None:
            self.game.close()
